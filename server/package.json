{
  "name": "server",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx --env-file=.env --watch -r tsconfig-paths/register src/index.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json --dir dist",
    "start": "node --env-file=.env -r tsconfig-paths/register dist/index.js"
  },
  "dependencies": {
    "@app/shared": "workspace:*",
    "@hono/node-server": "^1.19.14",
    "@hono/zod-validator": "^0.7.6",
    "hono": "^4.12.18",
    "mongoose": "^9.6.2",
    "mongoose-paginate-v2": "^1.9.4",
    "zod": "^4.4.3",
    "zod-validation-error": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.7.1",
    "typescript": "^5.8.3"
  }
}